#!/usr/bin/env python3
# /// script
# requires-python = ">=3.8"
# dependencies = ["numpy"]
# ///
"""wav2waveform -- centred-playhead waveform visualisation for YouTube videos.

Reads a WAV file and produces an H.264 video of the audio waveform scrolling
past a fixed centre playhead.  The current playback position is bright green;
past (left) and future (right) fade smoothly to black.

Designed to overlay the lower-right 960x540 quarter of a 1920x1080 frame.
Called automatically by gcs2youtube when available.
"""

import argparse
import math
import subprocess
import sys
import wave

import numpy as np


# ---------------------------------------------------------------------------
# Envelope computation
# ---------------------------------------------------------------------------

def compute_envelope(wav_path, samples_per_bin):
    """Return (peak, rms) envelope arrays, plus sample_rate and n_frames."""
    wf = wave.open(wav_path, 'rb')
    n_ch  = wf.getnchannels()
    sw    = wf.getsampwidth()
    sr    = wf.getframerate()
    n_frm = wf.getnframes()

    if sw != 2:
        print(f"Warning: expected 16-bit WAV, got {sw*8}-bit; "
              "treating as int16 anyway.", file=sys.stderr)

    n_bins = n_frm // samples_per_bin + 1
    peak = np.zeros(n_bins, dtype=np.float32)
    rms  = np.zeros(n_bins, dtype=np.float32)

    chunk_frames = samples_per_bin * 256        # read ~256 bins at a time
    bin_idx      = 0
    read_so_far  = 0

    while read_so_far < n_frm:
        to_read = min(chunk_frames, n_frm - read_so_far)
        raw     = wf.readframes(to_read)
        read_so_far += to_read

        data = np.frombuffer(raw, dtype=np.int16).astype(np.float32)
        if n_ch > 1:
            data = data.reshape(-1, n_ch).mean(axis=1)
        data /= 32768.0

        for i in range(0, len(data), samples_per_bin):
            if bin_idx >= n_bins:
                break
            c = data[i : i + samples_per_bin]
            if len(c):
                peak[bin_idx] = np.max(np.abs(c))
                rms[bin_idx]  = np.sqrt(np.mean(c * c))
            bin_idx += 1

    wf.close()
    return peak, rms, sr, n_frm


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    ap = argparse.ArgumentParser(
        description='Centred-playhead waveform visualisation video')
    ap.add_argument('input_wav',    help='Input WAV file')
    ap.add_argument('output_video', help='Output H.264 video file')
    ap.add_argument('--width',  type=int,   default=960)
    ap.add_argument('--height', type=int,   default=540)
    ap.add_argument('--fps',    type=int,   default=15)
    ap.add_argument('--window', type=float, default=10.0,
                    help='Seconds of audio visible (default 10)')
    args = ap.parse_args()

    W, H, FPS = args.width, args.height, args.fps

    # -- Read WAV header -----------------------------------------------------
    wf = wave.open(args.input_wav, 'rb')
    sr = wf.getframerate()
    nf = wf.getnframes()
    wf.close()

    spb = max(1, int(args.window * sr / W))     # samples per envelope bin

    print(f"[wav2waveform] computing envelope (spb={spb}) ...",
          file=sys.stderr)
    env_peak, env_rms, sr, nf = compute_envelope(args.input_wav, spb)
    n_env = len(env_peak)

    duration = nf / sr
    n_frames = int(math.ceil(duration * FPS))

    print(f"[wav2waveform] {duration:.1f}s  {sr}Hz  envelope={n_env}  "
          f"video={W}x{H}@{FPS}fps  frames={n_frames}", file=sys.stderr)

    # -- Horizontal fade (bright centre, black edges) ------------------------
    cx   = W / 2.0
    xs   = np.arange(W, dtype=np.float32)
    dist = np.abs(xs - cx) / cx                          # 0 at centre, 1 at edges
    fade = np.clip(1.0 - dist * dist, 0, 1) ** 1.5       # bell-shaped curve

    # -- Vertical geometry ---------------------------------------------------
    half_h = H / 2.0
    ys     = np.abs(np.arange(H, dtype=np.float32) - half_h)  # (H,)
    GLOW   = 6.0       # soft-edge width in pixels

    # -- Global peak (for max-value reference lines) -------------------------
    global_peak = float(np.max(env_peak)) if n_env else 0.0
    max_px = int(global_peak * half_h)  # pixel offset from centre
    print(f"[wav2waveform] global peak={global_peak:.3f}  "
          f"max line at +/-{max_px}px", file=sys.stderr)

    # -- Start ffmpeg encoder ------------------------------------------------
    cmd = [
        'ffmpeg', '-y', '-v', 'warning',
        '-f', 'rawvideo', '-pix_fmt', 'rgb24',
        '-s', f'{W}x{H}', '-r', str(FPS),
        '-i', 'pipe:0',
        '-c:v', 'libx264', '-pix_fmt', 'yuv420p',
        '-preset', 'fast', '-crf', '23',
        args.output_video,
    ]
    enc = subprocess.Popen(cmd, stdin=subprocess.PIPE, stderr=subprocess.PIPE)

    # Pre-allocate reusable buffers
    frame  = np.zeros((H, W, 3), dtype=np.uint8)
    pk_buf = np.zeros(W, dtype=np.float32)
    rm_buf = np.zeros(W, dtype=np.float32)

    ys2    = ys.reshape(-1, 1)          # (H, 1)  -- for broadcasting
    fade2d = fade.reshape(1, -1)        # (1, W)

    for fi in range(n_frames):
        if fi % (FPS * 30) == 0:
            print(f"  frame {fi}/{n_frames}  ({100.0*fi/n_frames:.0f}%)",
                  file=sys.stderr)

        t = fi / FPS
        centre_bin = t * sr / spb

        # -- Slice envelope centred on current position ----------------------
        start = int(centre_bin) - W // 2
        end   = start + W

        pk_buf[:] = 0
        rm_buf[:] = 0
        s0 = max(0, start)
        s1 = min(n_env, end)
        if s0 < s1:
            d0 = s0 - start
            pk_buf[d0 : d0 + s1 - s0] = env_peak[s0:s1]
            rm_buf[d0 : d0 + s1 - s0] = env_rms[s0:s1]

        # Pixel half-heights
        pk_h = pk_buf * half_h          # (W,)
        rm_h = rm_buf * half_h

        # -- Soft-edge masks (H, W) -----------------------------------------
        pk_soft = np.clip(1.0 - (ys2 - pk_h.reshape(1, -1)) / GLOW, 0, 1)
        rm_soft = np.clip(1.0 - (ys2 - rm_h.reshape(1, -1)) / GLOW, 0, 1)

        # Brightness: peak area 0.35, rms area adds 0.55  (max 0.90)
        brt = pk_soft * 0.35 + rm_soft * 0.55
        brt *= fade2d                   # horizontal fade

        # Centre axis: faint green line
        cr = int(half_h)
        brt[cr, :] = np.maximum(brt[cr, :], 0.08 * fade)

        # Max-value reference lines (above and below centre)
        if max_px > 0:
            for dy in (0, 1):           # 2 px thick
                y_top = cr - max_px + dy
                y_bot = cr + max_px - dy
                if 0 <= y_top < H:
                    brt[y_top, :] = np.maximum(brt[y_top, :], 0.22 * fade)
                if 0 <= y_bot < H:
                    brt[y_bot, :] = np.maximum(brt[y_bot, :], 0.22 * fade)

        # Playhead: bright vertical line at centre column (3 px wide)
        pc = W // 2
        for dx in (-1, 0, 1):
            col = pc + dx
            if 0 <= col < W:
                brt[:, col] = np.maximum(brt[:, col], 0.40)

        # -- Write frame (pure green) ---------------------------------------
        g = (brt * 255).clip(0, 255).astype(np.uint8)
        frame[:, :, 0] = 0
        frame[:, :, 1] = g
        frame[:, :, 2] = 0

        enc.stdin.write(frame.tobytes())

    enc.stdin.close()
    rc = enc.wait()
    if rc != 0:
        err = enc.stderr.read().decode(errors='replace')
        print(f"[wav2waveform] ffmpeg error (rc={rc}): {err}",
              file=sys.stderr)
        sys.exit(1)

    print(f"[wav2waveform] done -> {args.output_video}", file=sys.stderr)


if __name__ == '__main__':
    main()
