+/**
+ * Set the file renderer for a command handler.
+ * When set, the sleep command will render audio frames to the file
+ * instead of sleeping the thread.
+ *
+ * @param handler Command handler
+ * @param renderer File renderer instance, or NULL to disable
+ */
+void
+fluid_cmd_handler_set_renderer(fluid_cmd_handler_t *handler, fluid_file_renderer_t *renderer)
+{
+    fluid_return_if_fail(handler != NULL);
+    handler->renderer = renderer;
+    handler->pending_samples = 0.0;
+}
