#!/usr/bin/env python3
"""fs2ass -- Generate an ASS subtitle file with scrolling echo events.

Reads a .fs (FluidSynth) file, extracts timed echo lines, and produces
an ASS (Advanced SubStation Alpha) subtitle file.

All echo lines form a virtual document.  A "camera" pans through this
document at variable speed: the scroll rate adapts so that lines at a
given timestamp reach screen centre at exactly that time.  When two
measures are close together the scroll is slow; when many lines
separate them the scroll is fast.  Lines sit right next to each other.

A persistent white title can be placed near the top of the frame with
--title "line".  The scrolling orange text (Layer 1) overwrites the
white title (Layer 0) while passing; the title reappears once the
orange moves past.

Usage:
    fs2ass  input.fs  output.ass  [--title "line"] ...  [--filter REGEX]

Options:
    --title LINE     Display LINE as persistent white title near the top.
                     May be repeated for multiple title lines.
    --filter REGEX   Only display echoes whose text matches REGEX
                     (default: show ALL echoes)
"""

import re
import sys

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
VIDEO_W      = 1920
VIDEO_H      = 1080
FONT_NAME    = "DejaVu Sans"
FONT_SIZE    = 24           # scrolling echo text
TITLE_SIZE   = 48           # persistent title
LINE_HEIGHT  = 30           # tight vertical spacing — lines next to each other
TEXT_X       = 50           # left margin for scrolling text
CENTER_Y     = VIDEO_H // 2 # vertical centre where the active line sits

# Fade: text becomes transparent as it approaches the screen edges.
# FADE_RANGE = distance (px) from centre at which text is fully transparent.
FADE_RANGE   = CENTER_Y     # fade over the full half-screen

# Colour  (ASS &HAABBGGRR — note BGR order)
CLR_ORANGE   = "&H0000A5FF"
CLR_WHITE    = "&H00FFFFFF"

# ---------------------------------------------------------------------------
# Parse .fs file
# ---------------------------------------------------------------------------
def parse_fs_echoes(fs_path):
    """Yield (time_sec, text) for every echo line."""
    time_ms = 0.0
    re_sleep = re.compile(r'^sleep\s+([\d.]+)')
    re_echo  = re.compile(r'^echo\s+"(.*)"')
    with open(fs_path) as fh:
        for raw in fh:
            line = raw.rstrip('\n')
            m = re_sleep.match(line)
            if m:
                time_ms += float(m.group(1))
                continue
            m = re_echo.match(line)
            if m:
                yield (time_ms / 1000.0, m.group(1).rstrip())
            # fi
        # rof
    # htiw


def filter_echoes(echoes, user_filter=None):
    """Apply display filter.  Returns list of (time, text).

    By default ALL non-empty echoes are kept.  If user_filter is given,
    only lines matching the regex are kept.
    """
    result = []
    for t, txt in echoes:
        if not txt:
            continue
        if user_filter is not None:
            if user_filter.search(txt):
                result.append((t, txt))
            continue
        # fi
        result.append((t, txt))
    # rof
    return result


# ---------------------------------------------------------------------------
# Group by timestamp
# ---------------------------------------------------------------------------
def _group_by_time(events, epsilon=0.01):
    """Group events that share the same timestamp (within epsilon seconds).

    Returns a list of (time, [text, text, ...]) tuples.
    """
    groups = []
    n = len(events)
    i = 0
    while i < n:
        j = i + 1
        while j < n and abs(events[j][0] - events[i][0]) < epsilon:
            j += 1
        groups.append((events[i][0], [events[k][1] for k in range(i, j)]))
        i = j
    # elihw
    return groups


# ---------------------------------------------------------------------------
# Camera model
# ---------------------------------------------------------------------------
def _build_camera(events):
    """Build a piecewise-linear camera from echo events.

    Returns
    -------
    doc_y : list[float]
        Virtual document y-position for every echo line.
        doc_y[i] = i * LINE_HEIGHT.
    keyframes : list[tuple[float, float]]
        (time, camera_y) pairs sorted by time.  At each timestamp the
        camera centres on the midpoint of the lines at that time.
    """
    n = len(events)
    doc_y = [i * LINE_HEIGHT for i in range(n)]

    groups = _group_by_time(events)
    keyframes = []
    idx = 0
    for grp_time, texts in groups:
        grp_size = len(texts)
        mid_y = (doc_y[idx] + doc_y[idx + grp_size - 1]) / 2.0
        keyframes.append((grp_time, mid_y))
        idx += grp_size
    # rof

    return doc_y, keyframes


def _cam_y_at(t, kf):
    """Piecewise-linear camera position at time *t*."""
    if not kf:
        return 0.0
    if t <= kf[0][0]:
        return kf[0][1]
    if t >= kf[-1][0]:
        return kf[-1][1]
    for i in range(len(kf) - 1):
        t0, y0 = kf[i]
        t1, y1 = kf[i + 1]
        if t <= t1:
            if t1 <= t0:
                return y0
            return y0 + (y1 - y0) * (t - t0) / (t1 - t0)
        # fi
    # rof
    return kf[-1][1]


# ---------------------------------------------------------------------------
# ASS helpers
# ---------------------------------------------------------------------------
def _ass_time(seconds):
    """Format seconds as  H:MM:SS.cc  (centiseconds)."""
    if seconds < 0:
        seconds = 0
    h  = int(seconds // 3600)
    m  = int((seconds % 3600) // 60)
    s  = seconds % 60
    cs = int(round((s - int(s)) * 100))
    if cs >= 100:
        cs = 99
    return f'{h}:{m:02d}:{int(s):02d}.{cs:02d}'


def _escape(text):
    """Escape ASS special characters."""
    return text.replace('\\', '\\\\').replace('{', '\\{').replace('}', '\\}')


def _alpha_for_y(y):
    """ASS alpha (0 = opaque, 255 = transparent) from screen-y position.

    Uses a power curve so that text stays bright across a wide centre
    zone and fades quickly only near the screen edges.
    """
    dist = abs(y - CENTER_Y)
    if dist >= FADE_RANGE:
        return 255
    frac = dist / FADE_RANGE          # 0 at centre, 1 at edge
    return int(255 * frac ** 2.5)


# ---------------------------------------------------------------------------
# ASS generation
# ---------------------------------------------------------------------------
def generate_ass(events, total_duration, title_lines=None):
    r"""Build the full ASS file content.

    For each echo line, one ASS Dialogue is emitted per camera-speed
    segment in which the line is visible on screen.  Within each segment
    the camera speed (and therefore the line's scroll speed) is constant,
    so a single \move accurately describes the motion.

    Fading is position-based: lines are brightest at screen centre and
    fully transparent at the top/bottom edges.
    """
    doc_y, keyframes = _build_camera(events)

    # Segment boundaries: camera speed changes at each keyframe time.
    seg_times = sorted(set(
        [0.0] + [t for t, _ in keyframes] + [total_duration]
    ))
    # Pre-compute camera y at every segment boundary
    seg_cam = [_cam_y_at(t, keyframes) for t in seg_times]

    dialogues = []

    # --- Persistent title (Layer 0, Title style) ---
    if title_lines:
        title_text = '\\N'.join(_escape(l) for l in title_lines)
        dialogues.append(
            f'Dialogue: 0,0:00:00.00,{_ass_time(total_duration)},'
            f'Title,,0,0,0,,{title_text}'
        )
    # fi

    # --- Centre marker (Layer 2) -- bright triangle showing current position ---
    msz = 10
    dialogues.append(
        f'Dialogue: 2,0:00:00.00,{_ass_time(total_duration)},'
        f'Default,,0,0,0,,'
        f'{{\\an5\\pos(18,{CENTER_Y})\\1c&H00FFFF&\\bord0\\shad0\\p1}}'
        f'm 0 -{msz} l {int(msz * 1.2)} 0 l 0 {msz}'
    )

    # --- Scrolling echo lines (Layer 1, Default style) ---
    n_segs = len(seg_times) - 1

    for i in range(len(events)):
        dy = doc_y[i]
        text = _escape(events[i][1])

        for s in range(n_segs):
            ta = seg_times[s]
            tb = seg_times[s + 1]
            if tb - ta < 0.001:
                continue

            # Screen-y at segment start / end
            sya = dy - seg_cam[s]     + CENTER_Y
            syb = dy - seg_cam[s + 1] + CENTER_Y

            # Off the top already?  Line only moves upward over time.
            margin = LINE_HEIGHT * 2
            if max(sya, syb) < -margin:
                break                   # gone above — won't come back
            # Not yet on screen from the bottom?
            if min(sya, syb) > VIDEO_H + margin:
                continue                # hasn't entered yet

            # Alpha at endpoints
            aa = _alpha_for_y(sya)
            ab = _alpha_for_y(syb)
            dt_ms = max(1, int((tb - ta) * 1000))

            # Build \fade tag  (position-based transparency)
            crosses_centre = (sya - CENTER_Y) * (syb - CENTER_Y) < 0
            if crosses_centre and abs(sya - syb) > 0.5:
                frac = abs(sya - CENTER_Y) / abs(sya - syb)
                tc_ms = max(0, min(dt_ms, int(frac * dt_ms)))
                fade = f'\\fade({aa},0,{ab},0,{tc_ms},{tc_ms},{dt_ms})'
            else:
                # Linear alpha transition over the segment
                fade = f'\\fade({aa},{ab},{ab},0,{dt_ms},{dt_ms},{dt_ms})'
            # fi

            override = (
                f'{{\\an4'
                f'\\move({TEXT_X},{int(sya)},{TEXT_X},{int(syb)})'
                f'{fade}'
                f'}}'
            )

            dialogues.append(
                f'Dialogue: 1,{_ass_time(ta)},{_ass_time(tb)},'
                f'Default,,0,0,0,,{override}{text}'
            )
        # rof  (segments)
    # rof  (lines)

    return _ass_header() + '\n'.join(dialogues) + '\n'


def _ass_header():
    return f"""[Script Info]
Title: Music Echo Overlay
ScriptType: v4.00+
WrapStyle: 0
ScaledBorderAndShadow: yes
YCbCr Matrix: TV.709
PlayResX: {VIDEO_W}
PlayResY: {VIDEO_H}

[V4+ Styles]
Format: Name, Fontname, Fontsize, PrimaryColour, SecondaryColour, OutlineColour, BackColour, Bold, Italic, Underline, StrikeOut, ScaleX, ScaleY, Spacing, Angle, BorderStyle, Outline, Shadow, Alignment, MarginL, MarginR, MarginV, Encoding
Style: Default,{FONT_NAME},{FONT_SIZE},{CLR_ORANGE},&H000000FF,&H00000000,&H64000000,0,0,0,0,100,100,0,0,1,2,0,7,{TEXT_X},0,0,1
Style: Title,{FONT_NAME},{TITLE_SIZE},{CLR_WHITE},&H000000FF,&H00000000,&H80000000,-1,0,0,0,100,100,0,0,1,2,1,8,150,0,30,1

[Events]
Format: Layer, Start, End, Style, Name, MarginL, MarginR, MarginV, Effect, Text
"""


# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------
def main():
    if len(sys.argv) < 3 or sys.argv[1] in ('-h', '--help'):
        print(__doc__.strip(), file=sys.stderr)
        sys.exit(0 if '--help' in sys.argv else 1)
    # fi

    fs_path  = sys.argv[1]
    ass_path = sys.argv[2]

    user_filter = None
    title_lines = []

    # Parse optional arguments
    i = 3
    while i < len(sys.argv):
        if sys.argv[i] == '--filter' and i + 1 < len(sys.argv):
            user_filter = re.compile(sys.argv[i + 1])
            i += 2
        elif sys.argv[i] == '--title' and i + 1 < len(sys.argv):
            title_lines.append(sys.argv[i + 1])
            i += 2
        else:
            i += 1
        # fi
    # elihw

    raw_events = list(parse_fs_echoes(fs_path))
    if not raw_events:
        print('fs2ass: no echo events found in', fs_path, file=sys.stderr)
        sys.exit(1)
    # fi

    events = filter_echoes(raw_events, user_filter)
    if not events:
        print('fs2ass: all echo events filtered out; using unfiltered',
              file=sys.stderr)
        events = [(t, txt) for t, txt in raw_events if txt.strip()]
    # fi

    # Total duration from accumulated sleep in the .fs file
    total_sleep_ms = 0.0
    re_sleep = re.compile(r'^sleep\s+([\d.]+)')
    with open(fs_path) as fh:
        for raw in fh:
            m = re_sleep.match(raw.rstrip('\n'))
            if m:
                total_sleep_ms += float(m.group(1))
    total_dur = total_sleep_ms / 1000.0 + 2.0   # small buffer

    ass_content = generate_ass(events, total_dur, title_lines or None)

    with open(ass_path, 'w') as fh:
        fh.write(ass_content)
    # htiw

    n_dialogues = ass_content.count('\nDialogue:')
    print(f'fs2ass: wrote {ass_path}  ({len(events)} lines, '
          f'{n_dialogues} dialogue events, {total_dur:.1f}s)',
          file=sys.stderr)


if __name__ == '__main__':
    main()
