#!/usr/bin/env python3
"""fs2echolist -- Extract timed echo events from a .fs (FluidSynth) file.

Parses the .fs file, accumulating sleep times to compute the absolute
timestamp (in seconds) of each 'echo "..."' line.  Outputs a simple
tab-separated list:

    <seconds>\t<echo text>

This is consumed by gcs2youtube to build a scrolling-text video overlay.

Usage:
    fs2echolist  input.fs  [output.tsv]       # write to file or stdout
"""

import re
import sys

def parse_fs_echoes(fs_path):
    """Yield (time_seconds, text) for every echo line in the .fs file."""
    time_ms = 0.0
    re_sleep = re.compile(r'^sleep\s+([\d.]+)')
    re_echo  = re.compile(r'^echo\s+"(.*)"')

    with open(fs_path, 'r') as fh:
        for line in fh:
            line = line.rstrip('\n')
            m = re_sleep.match(line)
            if m:
                time_ms += float(m.group(1))
                continue
            m = re_echo.match(line)
            if m:
                yield (time_ms / 1000.0, m.group(1))
            # fi
        # rof
    # htiw
# End of parse_fs_echoes


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ('-h', '--help'):
        print(__doc__.strip(), file=sys.stderr)
        sys.exit(0 if sys.argv[1:] else 1)
    # fi

    fs_path = sys.argv[1]
    out_fh = open(sys.argv[2], 'w') if len(sys.argv) >= 3 else sys.stdout

    for t, text in parse_fs_echoes(fs_path):
        out_fh.write(f'{t:.3f}\t{text}\n')
    # rof

    if out_fh is not sys.stdout:
        out_fh.close()
    # fi
# End of main


if __name__ == '__main__':
    main()
