#!/bin/bash
# mp4cat -- Concatenate .mp4 files with silent black gaps between them.
#
# Produces a single .mp4 by joining the inputs in order, inserting a
# short silent black-screen gap between each pair.  Uses the ffmpeg
# concat demuxer with -c copy (no re-encoding) so it is very fast.
#
# The gap video is generated once per invocation to match the standard
# gcs2youtube output parameters (1920x1080, 15 fps, AAC 96 kHz stereo).
#
# Usage:
#     mp4cat [-o output.mp4] [-g seconds] file1.mp4 file2.mp4 ...
#
# Options:
#     -o, --output FILE   Output filename (default: combined.mp4)
#     -g, --gap SECS      Gap duration in seconds (default: 5)
#     -h, --help          Show this help message
#
# Requirements: ffmpeg
# -----------------------------------------------------------------------------

set -euo pipefail

die()  { echo "ERROR: $*" >&2; exit 1; }
info() { echo "-- $*"; }

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS] file1.mp4 file2.mp4 ...

Concatenate .mp4 files with silent black gaps between them.

Options:
  -o, --output FILE   Output filename (default: combined.mp4)
  -g, --gap SECS      Gap duration in seconds between songs (default: 5)
  -h, --help          Show this help message

Examples:
  $(basename "$0") b9m1.mp4 b9m2.mp4 b9m3.mp4
  $(basename "$0") -o symphony9.mp4 -g 3 b9m1.mp4 b9m2.mp4 b9m3.mp4 b9m4.mp4
EOF
    exit 0
}

# -- Defaults -----------------------------------------------------------------
OUTPUT="combined.mp4"
GAP_SECS=5

# Video/audio settings — must match gcs2youtube output
VIDEO_RES="1920x1080"
VIDEO_FPS="15"
AUDIO_RATE="96000"
# -----------------------------------------------------------------------------

# -- Parse options ------------------------------------------------------------
while [[ $# -gt 0 ]]; do
    case "$1" in
        -o|--output)  OUTPUT="$2";   shift 2 ;;
        -g|--gap)     GAP_SECS="$2"; shift 2 ;;
        -h|--help)    usage ;;
        -*)           die "Unknown option: $1" ;;
        *)            break ;;
    esac
done

[[ $# -ge 1 ]] || die "No input files.  Use --help for usage."

# Verify all inputs exist before doing any work
for f in "$@"; do
    [[ -f "$f" ]] || die "File not found: $f"
done

# Single file — just copy
if [[ $# -eq 1 ]]; then
    cp -- "$1" "$OUTPUT"
    info "Single file — copied to $OUTPUT"
    ls -lh "$OUTPUT"
    exit 0
fi

# -- Temp directory (cleaned up on exit) --------------------------------------
TMPDIR="$(mktemp -d)"
trap 'rm -rf "$TMPDIR"' EXIT

# -- Generate gap video -------------------------------------------------------
GAP_FILE="$TMPDIR/gap.mp4"
info "Generating ${GAP_SECS}s gap video..."
ffmpeg -y \
    -f lavfi -i "color=c=black:s=${VIDEO_RES}:r=${VIDEO_FPS}:d=${GAP_SECS}" \
    -f lavfi -i "anullsrc=r=${AUDIO_RATE}:cl=stereo" \
    -t "$GAP_SECS" \
    -c:v libx264 -tune stillimage -pix_fmt yuv420p \
    -c:a aac -b:a 192k \
    -shortest \
    -movflags +faststart \
    "$GAP_FILE" \
    2>/dev/null \
    || die "Failed to generate gap video."

# -- Build concat list --------------------------------------------------------
CONCAT_LIST="$TMPDIR/concat.txt"
FIRST=1
for f in "$@"; do
    FULL="$(cd "$(dirname "$f")" && pwd)/$(basename "$f")"
    if [[ "$FIRST" -eq 1 ]]; then
        FIRST=0
    else
        echo "file '$GAP_FILE'" >> "$CONCAT_LIST"
    fi
    echo "file '$FULL'" >> "$CONCAT_LIST"
done

info "Concatenating $# files with ${GAP_SECS}s gaps..."
sed 's/^/   /' "$CONCAT_LIST"

# -- Concatenate (with re-encode to preserve timing) -------------------------
ffmpeg -y -f concat -safe 0 -i "$CONCAT_LIST" \
    -c:v libx264 -tune stillimage -pix_fmt yuv420p \
    -c:a aac -b:a 192k \
    -movflags +faststart \
    "$OUTPUT" \
    || die "ffmpeg concatenation failed."

info "Done!  Combined file: $OUTPUT"
ls -lh "$OUTPUT"
